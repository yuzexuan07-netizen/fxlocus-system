# Copy this file to .env.local for local development.
# Do not put real secrets into a public GitHub repository.

APP_BASE_URL=http://localhost:3000
SYSTEM_COOKIE_DOMAIN=

# Cloudflare D1 database name used by helper scripts.
D1_NAME=fxlocus-system

# Cloudflare R2 object storage.
R2_BUCKET=fxlocus-system-files
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
R2_CDN_BASE_URL=
NEXT_PUBLIC_R2_CDN_BASE_URL=

# Logical bucket names stored in database rows.
SYSTEM_FILES_BUCKET=fxlocus-system-files
SYSTEM_CLASSIC_TRADES_BUCKET=fxlocus-system-files
SYSTEM_WEEKLY_SUMMARIES_BUCKET=fxlocus-system-files
SYSTEM_SUMMARY_IMAGES_BUCKET=fxlocus-system-files
SYSTEM_CONSULT_BUCKET=fxlocus-system-files

# Optional desktop/mobile download metadata.
R2_DESKTOP_PREFIX=desktop
R2_MOBILE_PREFIX=mobile
IOS_DOWNLOAD_URL=
NEXT_PUBLIC_IOS_DOWNLOAD_URL=

# Optional system retention cron secrets.
TRADE_LOG_RETENTION_SECRET=
SYSTEM_RETENTION_SECRET=
CONSULT_RETENTION_SECRET=

# Optional UI settings.
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_LADDER_IMAGE_URL=
NEXT_PUBLIC_LADDER_REFRESH_MS=60000
NEXT_PUBLIC_STORE_CLOUD_PC_WECHAT_URL=
NEXT_PUBLIC_STORE_CLOUD_PC_ALIPAY_URL=

# Optional consult call TURN settings. Leave blank if you do not use audio calls across strict networks.
NEXT_PUBLIC_WEBRTC_TURN_URLS=
NEXT_PUBLIC_WEBRTC_TURN_USERNAME=
NEXT_PUBLIC_WEBRTC_TURN_CREDENTIAL=

# Optional rate limits.
MIDDLEWARE_LOGIN_RATE_WINDOW_MS=60000
MIDDLEWARE_LOGIN_RATE_LIMIT_PER_IP=80
LOGIN_RATE_LIMIT_STORE=d1
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS_IP=60
LOGIN_RATE_LIMIT_MAX_ATTEMPTS_EMAIL=10
